# ============================================
# TaleVoice 环境变量配置（示例）
# ============================================
# 复制此文件为 .env 并修改配置值

# ---------- PostgreSQL 配置 ----------
POSTGRES_DB=talevoice
POSTGRES_USER=talevoice
POSTGRES_PASSWORD=your_password_here
POSTGRES_PORT=5432
DATABASE_URL=postgresql://talevoice:your_password_here@localhost:5432/talevoice

# ---------- Redis 配置 ----------
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379
REDIS_URL=redis://:your_redis_password_here@localhost:6379/0

# ---------- 应用配置 ----------
APP_NAME=TaleVoice
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=your_secret_key_here

# ---------- JWT 配置 ----------
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- Celery 配置 ----------
CELERY_BROKER_URL=redis://:your_redis_password_here@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:your_redis_password_here@localhost:6379/2
