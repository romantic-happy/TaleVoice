# TaleVoice 应用配置
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_NAME=TaleVoice
DEBUG=true

# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/tale_voice

# JWT配置
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256

# 阿里云OSS配置
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_BUCKET_NAME=your-bucket-name
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_CDN_DOMAIN=

# AI视频生成服务商配置 (mock/aliyun)
AI_PROVIDER=aliyun

# 阿里云通义万相视频生成API配置
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_VIDEO_API_KEY=your-dashscope-api-key
ALIYUN_VIDEO_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/video-generation
ALIYUN_VIDEO_MODEL=wanx2.1-i2v-plus

# 阿里云通义千问大模型API配置（提示词工程）
ALIYUN_LLM_API_KEY=your-dashscope-api-key
ALIYUN_LLM_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
ALIYUN_LLM_MODEL=qwen-max

# 阿里云语音合成API配置
ALIYUN_TTS_APP_KEY=your-tts-app-key
ALIYUN_TTS_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_TTS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret

# 阿里云字幕生成API配置
ALIYUN_SUBTITLE_APP_KEY=your-subtitle-app-key
ALIYUN_SUBTITLE_CALLBACK_URL=

# 阿里云智能剪辑API配置
ALIYUN_EDIT_REGION=cn-shanghai
ALIYUN_EDIT_CALLBACK_URL=
ALIYUN_EDIT_OUTPUT_BUCKET=your-output-bucket-name

# OpenAI配置
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Qwen TTS配置
TTS_DEVICE=cpu
TTS_MODEL_NAME=Qwen/Qwen3-TTS-12Hz-1.7B-Base
TTS_LANGUAGE=Chinese
TTS_ATTENTION_IMPLEMENTATION=eager
